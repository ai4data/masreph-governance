# Copy this file to .env and fill in your values

# Azure OpenAI
AZURE_OPENAI_ENDPOINT="https://your-endpoint.cognitiveservices.azure.com/"
AZURE_OPENAI_API_KEY="your-api-key"
AZURE_OPENAI_API_VERSION="2025-01-01-preview"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-5.1"

# Supabase - catalog (dmp-masreph)
CATALOG_DB_HOST="your-host.pooler.supabase.com"
CATALOG_DB_PORT=5432
CATALOG_DB_NAME="postgres"
CATALOG_DB_USER="postgres.your-project-id"
CATALOG_DB_PASSWORD="your-password"

# Supabase - masreph-core (PostgreSQL platform)
MASREPH_PG_HOST="your-host.pooler.supabase.com"
MASREPH_PG_PORT=5432
MASREPH_PG_NAME="postgres"
MASREPH_PG_USER="postgres.your-project-id"
MASREPH_PG_PASSWORD="your-password"
SUPABASE_CORE_PASSWORD="your-password"

# Local PostgreSQL
LOCAL_PG_PASSWORD="your-password"

# MySQL
MYSQL_PASSWORD="your-password"

# Snowflake
SNOWFLAKE_ACCOUNT="your-account"
SNOWFLAKE_USER="your-user"
SNOWFLAKE_PASSWORD="your-password"
SNOWFLAKE_WAREHOUSE="COMPUTE_WH"
SNOWFLAKE_DATABASE="MASREPH_RISK_ANALYTICS"

# Oracle
ORACLE_USER="ADMIN"
ORACLE_PASSWORD="your-password"
ORACLE_DSN="your-dsn"

# MongoDB
MONGODB_USER="your-user"
MONGODB_PASSWORD="your-password"
MONGODB_CLUSTER="your-cluster.mongodb.net"

# Databricks
DATABRICKS_HOST="your-host.azuredatabricks.net"
DATABRICKS_HTTP_PATH="/sql/1.0/warehouses/your-warehouse-id"
DATABRICKS_TOKEN="your-token"

# Microsoft Fabric
FABRIC_SERVER="your-server.datawarehouse.fabric.microsoft.com"
FABRIC_DATABASE="MasrephCorporateBI_WH"
FABRIC_TENANT_ID="your-tenant-id"
FABRIC_CLIENT_ID="your-client-id"
FABRIC_CLIENT_SECRET="your-client-secret"
